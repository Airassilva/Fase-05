<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_map">

    <fragment
        android:id="@+id/nav_questions"
        android:name="dev.aira.saudeEmRota.ui.questions.QuestionsFragment"
        android:label="@string/menu_questions"
        tools:layout="@layout/fragment_questions">

        <argument
            android:name="usfId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null"/>

        <argument
            android:name="usfNome"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null"/>

        <action
            android:id="@+id/action_nav_questions_to_usfDetailFragment"
            app:destination="@id/usfDetailFragment"/>

    </fragment>

    <fragment
        android:id="@+id/nav_map"
        android:name="dev.aira.saudeEmRota.ui.map.MapFragment"
        android:label="@string/home_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout="@layout/fragment_map">
    <action
        android:id="@+id/action_nav_map_to_usfDetailFragment"
        app:destination="@id/usfDetailFragment"/>

    </fragment>

    <fragment
        android:id="@+id/nav_historic"
        android:name="dev.aira.saudeEmRota.ui.historic.HistoricFragment"
        android:label="@string/menu_historic"
        tools:layout="@layout/fragment_historic">

        <action
            android:id="@+id/action_nav_historic_to_usfDetailFragment"
            app:destination="@id/usfDetailFragment"/>

    </fragment>

    <fragment
        android:id="@+id/usfDetailFragment"
        android:name="dev.aira.saudeEmRota.ui.usf.UsfDetailFragment"
        android:label="Detalhes da USF"
        tools:layout="@layout/fragment_usf_detail">

        <argument
            android:name="usfId"
            app:argType="string"/>

        <action
            android:id="@+id/action_usfDetail_to_questions"
            app:destination="@id/nav_questions"
            app:popUpTo="@id/nav_map"
            app:popUpToInclusive="false"/>

    </fragment>
</navigation>